# ============================================================
# Sistema de Gestão de Imóveis - Mesquita Administração
# Arquivo de variáveis de ambiente - EXEMPLO
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# === VARIÁVEIS OBRIGATÓRIAS ===

# --- Banco de Dados (MySQL/TiDB) ---
# Formato: mysql://usuario:senha@host:porta/banco?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://usuario:senha@localhost:3306/sistema_aluguel

# --- Autenticação JWT ---
# Gere uma string aleatória segura (ex: openssl rand -base64 32)
# IMPORTANTE: Use uma chave forte com pelo menos 32 caracteres
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# === VARIÁVEIS OPCIONAIS (apenas na plataforma Manus) ===

# --- Manus OAuth (necessário apenas na plataforma Manus) ---
# Deixe em branco se não estiver usando a plataforma Manus
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# --- APIs internas Manus (necessário apenas na plataforma Manus) ---
# Deixe em branco se não estiver usando a plataforma Manus
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# === VARIÁVEIS OPCIONAIS (Analytics) ===
# Deixe em branco se não usar analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# === VARIÁVEIS OPCIONAIS (Branding) ===
VITE_APP_TITLE=Sistema de Gestão de Imóveis
VITE_APP_LOGO=
